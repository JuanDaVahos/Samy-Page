---
import Graphicvg from "../assets/svg/Graphic.svg";
---

<div class="towCol flex flex-col items-center">
  <section
    class="w-[90%] mt-4 mx-auto flex md:w-full max-w-6xl flex-col items-center gap-8 rounded-3xl border border-pink-200 bg-white/60 p-8 shadow-sm backdrop-blur-sm md:flex-row md:justify-center"
  >
    <div class="flex gap-2 items-center">
      <Graphicvg class="text-samy" />
      <h3>Entradas Y Salidas (HOY)</h3>
      <select
        name="EntradaFecha"
        id="EntradaFecha"
        class="border border-gray-400 rounded-[5px] p-1.5"
      >
        <option value="Hoy">Hoy</option>
        <option value="Ayer">Ayer</option>
        <option value="Mes">Mes</option>
      </select>
    </div>
  </section>
  <section
    class="w-[90%] mt-4 mx-auto flex md:w-full max-w-6xl flex-col items-center gap-8 rounded-3xl border border-pink-200 bg-white/60 p-8 shadow-sm backdrop-blur-sm md:flex-row md:justify-center"
  >
  </section>
</div>
