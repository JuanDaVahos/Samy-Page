---
import Graphicvg from "../assets/svg/Graphic.svg";
---

<section
  class="w-[90%] mt-4 mx-auto flex flex-col md:w-full max-w-6xl items-center gap-8 rounded-3xl border border-pink-200 bg-white/60 p-4 sm:p-8 shadow-sm backdrop-blur-sm md:justify-center"
>
  <div class="flex flex-col sm:flex-row gap-4 items-center justify-between w-full">
    <div class="flex items-center gap-3">
      <Graphicvg class="text-samy" />
      <h3>Entradas Y Salidas</h3>
    </div>
    <select
      name="EntradaFecha"
      id="EntradaFecha"
      class="border border-gray-400 rounded-[5px] p-1.5 w-full sm:w-auto"
    >
      <option value="Hoy">Hoy</option>
      <option value="Ayer">Ayer</option>
      <option value="Mes">Mes</option>
    </select>
  </div>
  <div class="w-full">
    <canvas id="EvS" class="w-full"> </canvas>
  </div>
</section>
<section
  class="w-[90%] mt-4 mx-auto flex md:w-full max-w-6xl flex-col items-center gap-8 rounded-3xl border border-pink-200 bg-white/60 p-4 sm:p-8 shadow-sm backdrop-blur-sm md:flex-row md:justify-center"
>
</section>

<script>
  import Chart from "chart.js/auto";
  const EvS = document.getElementById("EvS") as HTMLCanvasElement | null;

  if (EvS) {
    new Chart(EvS, {
      type: "bar",
      data: {
        labels: ["Entradas", "Salidas"],
        datasets: [
          {
            label: "Entradas Vs Salidas",
            data: [15000, 12300],
            backgroundColor: [
              "rgba(54, 162, 235, 0.2)",
              "rgba(255, 99, 132, 0.2)",
            ],
            borderWidth: 4,
            borderColor: ["rgba(54, 162, 235, 1)", "rgba(255, 99, 132, 1)"],
          },
        ],
      },
      options: {
        scales: {
          y: {
            beginAtZero: true,
          },
        },
      },
    });
  }
</script>
