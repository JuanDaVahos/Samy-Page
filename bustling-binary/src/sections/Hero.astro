---
import ImgWelcome from "../../public/imgWelcome.webp";
import Image from "astro/components/Image.astro";
import CalendarySvg from "../assets/svg/Calendary.svg";
import ClockSvg from "../assets/svg/Clock.svg";
import MoneySvg from "../assets/svg/Money.svg";
import ShopSvg from "../assets/svg/Shop.svg";
import WalletSvg from "../assets/svg/Wallet.svg";
import UpSvg from "../assets/svg/Up.svg";

// FECHA
const fechaHoy = new Date();
const fechaCortaCo = fechaHoy.toLocaleDateString("es-CO", {
  day: "numeric",
  month: "numeric",
  year: "numeric",
});

// HORA
const horaMedellin = new Date().toLocaleTimeString("es-CO", {
  hour: "2-digit",
  minute: "2-digit",
});
---

<main class="flex flex-col gap-2 md:gap-8">
  <section
    class="w-[90%] mt-4 mx-auto flex md:w-full max-w-6xl flex-col items-center gap-8 rounded-3xl border border-pink-200 bg-white/60 p-8 shadow-sm backdrop-blur-sm md:flex-row md:justify-center"
  >
    <!-- Imagen -->
    <div class="flex justify-center">
      <Image
        src={ImgWelcome}
        alt="Imagen de Bienvenida, Un helado Alegre"
        width={250}
        height={250}
        class="drop-shadow-lg"
      />
    </div>

    <!-- Información -->
    <div class="flex flex-col items-center md:items-start">
      <h1
        class="flex items-center gap-3 text-center text-5xl font-bold text-black"
      >
        <span>¡Bienvenido!</span>
        <span>🍦</span>
      </h1>

      <p class="mt-2 text-center text-lg text-gray-700 md:text-left">
        Aquí tienes el resumen general de la Heladería
      </p>

      <!-- Fecha y Hora -->
      <div
        class="mt-8 flex flex-wrap items-center justify-center gap-6 md:justify-start"
      >
        <div
          class="flex items-center gap-3 rounded-xl bg-white px-4 py-3 shadow-sm"
        >
          <CalendarySvg class="h-8 w-8" />

          <div>
            <p class="text-sm text-gray-500">Fecha</p>
            <strong class="text-samy">{fechaCortaCo}</strong>
          </div>
        </div>

        <div
          class="flex items-center gap-3 rounded-xl bg-white px-4 py-3 shadow-sm"
        >
          <ClockSvg class="h-8 w-8" />

          <div>
            <p class="text-sm text-gray-500">Hora</p>
            <strong class="text-samy">{horaMedellin}</strong>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section
    class="w-[90%] mt-4 mx-auto flex md:w-full max-w-6xl flex-col items-center gap-8 rounded-3xl border border-pink-200 bg-white/60 p-8 shadow-sm backdrop-blur-sm md:flex-row md:justify-center"
  >
    <article
      class="bg-white rounded-xl shadow-sm p-2 flex items-center gap-1 md:gap-2 w-[80%] justify-around"
    >
      <MoneySvg class="rounded-full p-2 bg-green-600 text-black w-16 h-16" />
      <div>
        <h3 class="font-bold">Ingresos Hoy</h3>
        <span>$99,999</span>
      </div>
    </article>
    <article
      class="bg-white rounded-xl shadow-sm p-2 flex items-center gap-1 md:gap-2 w-[80%] justify-around"
    >
      <ShopSvg class="rounded-full p-2 bg-indigo-500 text-black w-16 h-16" />
      <div>
        <h3 class="font-bold">Ventas Hoy</h3>
        <span>156</span>
      </div>
    </article>
    <article
      class="bg-white rounded-xl shadow-sm p-2 flex items-center gap-1 md:gap-2 w-[80%] justify-around"
    >
      <WalletSvg class="rounded-full p-2 bg-pink-500 text-black w-16 h-16" />
      <div>
        <h3 class="font-bold">Gastos Hoy</h3>
        <span>$99,999</span>
      </div>
    </article>
    <article
      class="bg-white rounded-xl shadow-sm p-2 flex items-center gap-1 md:gap-2 w-[80%] justify-around"
    >
      <UpSvg class="rounded-full p-2 bg-orange-500 text-black w-16 h-16" />
      <div>
        <h3 class="font-bold">Ganancias Hoy</h3>
        <span>$00,000</span>
      </div>
    </article>
  </section>
  <div class="towCol flex flex-col items-center">
    <section
      class="w-[90%] mt-4 mx-auto flex md:w-full max-w-6xl flex-col items-center gap-8 rounded-3xl border border-pink-200 bg-white/60 p-8 shadow-sm backdrop-blur-sm md:flex-row md:justify-center"
    >
    </section>
    <section
      class="w-[90%] mt-4 mx-auto flex md:w-full max-w-6xl flex-col items-center gap-8 rounded-3xl border border-pink-200 bg-white/60 p-8 shadow-sm backdrop-blur-sm md:flex-row md:justify-center"
    >
    </section>
  </div>
  <section class="ResumenMes"></section>
</main>
