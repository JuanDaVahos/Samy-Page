---
import CalendarySvg from "../assets/svg/Calendary.svg";
import MoneySvg from "../assets/svg/Money.svg";
import ShopSvg from "../assets/svg/Shop.svg";
import WalletSvg from "../assets/svg/Wallet.svg";
import UpSvg from "../assets/svg/Up.svg";
---

<section
  class="w-[90%] mt-4 mx-auto flex md:w-full max-w-6xl flex-col items-center gap-4 md:gap-8 rounded-3xl border border-pink-200 bg-white/60 p-4 sm:p-8 shadow-sm backdrop-blur-sm md:justify-center"
>
  <div class="flex items-center gap-3">
    <CalendarySvg class="text-samy" />
    <h3>Resumen Del Mes</h3>
  </div>
  <div
    class="flex gap-6 flex-col md:flex-row md:justify-center md:flex-wrap max-w-[900px]"
  >
    <div class="flex gap-2 p-4 rounded-xl shadow-sm min-w-[300px]">
      <MoneySvg class="rounded-full p-2 bg-green-600 text-black w-16 h-16" />
      <div>
        <p>Ingresos del mes</p>
        <strong>$3000000</strong>
        <p>Total de dinero ingresado</p>
      </div>
    </div>
    <div class="flex gap-2 p-4 rounded-xl shadow-sm min-w-[300px]">
      <WalletSvg class="rounded-full p-2 bg-pink-500 text-black w-16 h-16" />
      <div>
        <p>Gastos del mes</p>
        <strong>1600000</strong>
        <p>Total del dinero gastado</p>
      </div>
    </div>
    <div class="flex gap-2 p-4 rounded-xl shadow-sm min-w-[300px]">
      <UpSvg class="rounded-full p-2 bg-orange-500 text-black w-16 h-16" />
      <div>
        <p>Ganancias del mes</p>
        <strong>$1400000</strong>
        <p>Ingresos - Gastos</p>
      </div>
    </div>
    <div class="flex gap-2 p-4 rounded-xl shadow-sm min-w-[300px]">
      <ShopSvg class="rounded-full p-2 bg-indigo-500 text-black w-16 h-16" />
      <div>
        <p>Ventas totales</p>
        <strong>3,500</strong>
        <p>Todas las ventas del mes</p>
      </div>
    </div>
  </div>
  <button
    class="rounded-xl bg-samy/30 p-4 border border-samy/55 hover:cursor-pointer hover:bg-samy"
    >Ver Reporte mensual</button
  >
</section>
