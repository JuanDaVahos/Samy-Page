---
import MoneySvg from "../assets/svg/Money.svg";
import ShopSvg from "../assets/svg/Shop.svg";
import WalletSvg from "../assets/svg/Wallet.svg";
import UpSvg from "../assets/svg/Up.svg";
---

<section
  class="w-[90%] mt-4 mx-auto flex md:w-full max-w-6xl flex-col items-center gap-4 md:gap-8 rounded-3xl border border-pink-200 bg-white/60 p-4 sm:p-8 shadow-sm backdrop-blur-sm md:flex-row md:justify-center"
>
  <article
    class="bg-white rounded-xl shadow-sm p-4 flex items-center gap-3 w-full md:w-auto md:flex-1 justify-between sm:justify-around"
  >
    <MoneySvg class="rounded-full p-2 bg-green-600 text-black w-16 h-16" />
    <div>
      <h3 class="font-bold">Ingresos Hoy</h3>
      <span>$99,999</span>
    </div>
  </article>
  <article
    class="bg-white rounded-xl shadow-sm p-4 flex items-center gap-3 w-full md:w-auto md:flex-1 justify-between sm:justify-around"
  >
    <ShopSvg class="rounded-full p-2 bg-indigo-500 text-black w-16 h-16" />
    <div>
      <h3 class="font-bold">Ventas Hoy</h3>
      <span>156</span>
    </div>
  </article>
  <article
    class="bg-white rounded-xl shadow-sm p-4 flex items-center gap-3 w-full md:w-auto md:flex-1 justify-between sm:justify-around"
  >
    <WalletSvg class="rounded-full p-2 bg-pink-500 text-black w-16 h-16" />
    <div>
      <h3 class="font-bold">Gastos Hoy</h3>
      <span>$99,999</span>
    </div>
  </article>
  <article
    class="bg-white rounded-xl shadow-sm p-4 flex items-center gap-3 w-full md:w-auto md:flex-1 justify-between sm:justify-around"
  >
    <UpSvg class="rounded-full p-2 bg-orange-500 text-black w-16 h-16" />
    <div>
      <h3 class="font-bold">Ganancias Hoy</h3>
      <span>$00,000</span>
    </div>
  </article>
</section>
